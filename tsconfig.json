{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./ts/*"]
    }
  },
  "include": ["ts/**/*", "ts/**/*.vue", "ts/vue-shim.d.ts"],
  "exclude": ["node_modules"]
}
